# ============================================================================
# UI-R1 — .gitignore (regole universali, condivise)
#
# Solo regole utili a CHIUNQUE cloni il repo. Le regole personali
# (script scratch, backup, workflow remoto) vivono in .git/info/exclude
# (locale, non condiviso).
# ============================================================================

# --- Rust build ---
/target/
**/*.rs.bk

# --- Stato pre-trained binario (rigenerabile via bootstrap, vedi README) ---
# prometeo_kg.json e prometeo_kg_procedurale.json sono gestiti via Git LFS.
prometeo_topology_state.bin
*.bin.bak*
*.bin.pre_*
*_OLD_*.bin
*_REBUILD_OLD.bin
*_backup_*.bin

# --- Python ---
__pycache__/
*.pyc
*.pyo
.env

# --- Logs ---
*.log

# --- Backup generici ---
*.bak
*.bak2
*.bak3
*.bak4

# --- External datasets (grandi, scaricabili separatamente) ---
/data/external/*.gz
/data/external/*.tgz
/data/external/*.jsonl.gz
/data/external/*.jsonl
/data/external/ita_news_2023_100K/
/data/external/ita_wikipedia_2021_100K/
/data/external/current_version/
/data/external/wikidata_ita.tsv.bak
/data/external/wikidata_ita_filtered.tsv.bak

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- AI agent state (Claude Code, Kiro, Zencoder) ---
.claude/
.claude.json
/CLAUDE.md
.kiro/
.zencoder/
.zenflow/
.agents/

# --- OS artifacts ---
nul
Thumbs.db
.DS_Store
desktop.ini

# --- PDF / media grandi ---
*.pdf

# --- Snapshot JSON transienti dello stato ---
prometeo_state_*.json
prometeo_topology_state_*.json
prometeo_topology_state_BACKUP_*.json
*.bin.safety
prometeo_topology_state.json

# --- Cartelle research/scratch escluse dalla presentazione GitHub ---
# (per chi clona: queste possono esistere in locale, non vengono tracciate)
experiments/
lessons/
examples/
tools/
archive/

# Obsidian vault state (per-utente, non condiviso)
docs/wiki/.obsidian/workspace.json
docs/wiki/.obsidian/workspaces.json
docs/wiki/.obsidian/cache
docs/wiki/.obsidian/plugins/*/data.json

# Cartelle locali non pubblicate
roadmap_futuro/
campovasto-mobile/
